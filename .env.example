# Meta-API 중계 서버 환경변수 — 형식 안내용(값 비움).
# 실제 값은 이 파일을 복사해 `.env` 로 만들고 채운다. `.env` 는 커밋하지 않는다(.gitignore).
# 키 원본은 docs/_reference/KAYAK_접속정보_및_QA.md (이 파일도 커밋 금지).

# 중계 서버 포트
PORT=8787

# 운영 모드(S6). production 이면 기동 시 보안 설정을 강제 — 미흡하면 기동 실패(fail-fast).
# 운영 필수: RELAY_SHARED_SECRET 설정 / RATE_LIMIT_PER_MIN>0 / ALLOW_NO_ORIGIN=false /
#   ALLOWED_ORIGINS 에 localhost 미포함 / KAYAK 키 3종 로드. (개발은 development 로 두면 관대)
RELAY_ENV=development

# KAYAK affiliate 호스트 (운영 확정 = ko-kr · 실측. 샌드박스 sandbox-en-us 는 403)
KAYAK_HOST=https://ko-kr.kayakaffiliates.com
KAYAK_REPORTING_HOST=https://api.affiliates.hotelscombined.com

# 비밀 키 (KAYAK 전달본에서 복사 — 절대 커밋 금지)
KAYAK_API_KEY=
KAYAK_REPORTING_KEY=

# 딥링크 a= 값 (공개값·비밀 아님)
KAYAK_AFFILIATE_ID=kan_318930_594068

# 검색 API 필수 User-Agent (curl/Postman 기본값은 403/400 으로 차단됨)
KAYAK_SEARCH_UA=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# CORS 허용 오리진 (쉼표 구분) — 운영에서는 localhost 제거(없으면 기동 실패)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,https://meta-re.pages.dev

# ── 통화·언어 SSOT + 허용목록(S6·#21) ──
# KAYAK 계정 KRW 고정(다통화는 KAYAK 회신 대기). 비허용 통화/언어 요청은 400(무음 오표기 금지).
DEFAULT_CURRENCY=KRW
DEFAULT_LANGUAGE=ko_KR
SUPPORTED_CURRENCIES=KRW
SUPPORTED_LANGUAGES=ko_KR

# 자동완성 단기 캐시(ms·S6·#22) — 디바운스 타이핑 반복 쿼리의 KAYAK 호출 쿼터 절감(0=비활성)
AUTOCOMPLETE_CACHE_TTL_MS=60000

# ── 비동기 폴링 예산(검색·S1) — codex 권고 A=서버 블로킹 폴링 ──
KAYAK_POLL_INTERVAL_MS=1000
KAYAK_POLL_MAX_ATTEMPTS=10
KAYAK_POLL_TIMEOUT_MS=12000
KAYAK_REQUEST_TIMEOUT_MS=8000
# 폴링 중 연속 일시오류(네트워크/타임아웃/5xx·429) 재시도 상한(S6·#22)
KAYAK_POLL_MAX_TRANSIENT=3

# ── 캐시백 리포팅(S5) ──
# Reporting 조회 기본 창(일). startDate/endDate 미지정 시 최근 N일치 거래.
CASHBACK_LOOKBACK_DAYS=400
# 단일 페이지 조회 건수(초과 시 truncation 경고 로그)
CASHBACK_PAGE_SIZE=1000
# 정산 경과 추론 임계 '일'(ET 기준 paymentMonth 다음 달 N일 이후 → Approved·지급완료 추정)
CASHBACK_SETTLE_DAY=26
# 캐시백 라벨 서명(S6·IDOR 방어). 설정 시 /api/cashback 에 exp+sig(HMAC-SHA256(label.exp)) 강제.
# 인증 백엔드가 회원 본인 라벨에 발급. 미설정(개발/데모)이면 앱이 보낸 라벨을 신뢰(현행).
CASHBACK_LABEL_HMAC_SECRET=
# 라벨 서명 허용 최대 수명(초) — 발급 후 이보다 만료가 먼 장기 토큰은 거부(짧은 만료 권고)
CASHBACK_LABEL_MAX_AGE_SEC=300

# ── 보안 hook (개발=기본 비활성 / 운영 데모 전 켜기 · S6) ──
# 앱↔중계 공유 시크릿(설정 시 /api 요청에 x-relay-secret 헤더 강제)
RELAY_SHARED_SECRET=
# IP당 분당 최대 요청(0=비활성)
RATE_LIMIT_PER_MIN=0
# origin 없는 요청(curl·서버간) 허용(개발=true, 운영=false 권장)
ALLOW_NO_ORIGIN=true

# ── 클라이언트 IP 신뢰경계(codex #2/#13) ──
# 신뢰 프록시 hop 수(0=직결, CF/LB 뒤면 그 hop 수). 들어온 x-original-client-ip 는 무시.
TRUST_PROXY_HOPS=0
# 개발 폴백 client IP(localhost 등 산출 불가 시). 임의 IP 금지 → 개발실 egress.
DEV_CLIENT_IP=58.75.223.130
